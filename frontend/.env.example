# ──────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local for local development.
# .env.local is git-ignored and must NEVER be committed.
# ──────────────────────────────────────────────────────────────────────────
#
# LOCAL DEVELOPMENT:
#   Leave VITE_API_URL commented out (or completely absent).
#   Vite's proxy will forward /api/* → http://localhost:8000 automatically.
#   This avoids CORS issues and keeps frontend code free of hardcoded ports.
#
# PRODUCTION BUILD:
#   Uncomment and set VITE_API_URL to your deployed backend URL.
#
# VITE_API_URL=https://your-backend.onrender.com
