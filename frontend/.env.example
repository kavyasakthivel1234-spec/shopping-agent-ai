# frontend/.env.example
# Copy to .env.local for local development. Never commit .env.local.

# LOCAL DEVELOPMENT:
#   Leave VITE_API_URL unset — Vite proxy forwards /api/* → http://localhost:8000

# PRODUCTION:
#   Set to your deployed FastAPI backend URL
# VITE_API_URL=https://shopping-assistant-api-vhwh.onrender.com
