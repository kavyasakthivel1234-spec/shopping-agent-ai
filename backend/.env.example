# ────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is git-ignored and must NEVER be committed.
# ────────────────────────────────────────────────────────────────────────────

# ── Groq AI ──────────────────────────────────────────────────────────────
# Get a free key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here
MODEL_NAME=llama-3.3-70b-versatile

# ── CORS ─────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173

# ── App ──────────────────────────────────────────────────────────────────
APP_TITLE=AI Shopping Assistant API
APP_VERSION=4.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ── SerpAPI (optional — enables real Amazon product search) ──────────────
# Get a free key at: https://serpapi.com
# SERP_API_KEY=your_serpapi_key_here

# ── MongoDB Atlas ────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxx.mongodb.net/<dbname>?retryWrites=true&w=majority&appName=Cluster0

# ── JWT ──────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change_this_to_a_long_random_secret_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=7

# ── Gmail SMTP (for password reset emails) ───────────────────────────────
# The Gmail address used as the sender and for SMTP login.
EMAIL_ADDRESS=your_gmail@gmail.com
# Generate a 16-character App Password at: https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be enabled on your Google account)
EMAIL_PASSWORD=your_16_char_app_password

# ── Frontend URL (used in reset email link) ──────────────────────────────
FRONTEND_URL=http://localhost:5173
