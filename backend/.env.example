# backend/.env.example
# Copy to .env for local development. Never commit .env.

# Groq AI
GROQ_API_KEY=gsk_your_groq_api_key_here
MODEL_NAME=llama-3.3-70b-versatile

# SerpAPI — real Amazon product search (optional)
SERP_API_KEY=your_serpapi_key_here

# MongoDB Atlas
# Database name must be: shopping_assistant
# Atlas user needs readWrite on shopping_assistant
# Network Access must allow 0.0.0.0/0
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/shopping_assistant?retryWrites=true&w=majority

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# App
APP_TITLE=AI Shopping Assistant API
APP_VERSION=4.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8000
